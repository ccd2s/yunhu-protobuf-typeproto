{
  "name": "@nanoyunhu/yunhu-protobuf-typeproto",
  "version": "0.4.0",
  "description": "Yunhu's Code-First TypeScript Protobuf Implementation (Using Typeproto).",
  "license": "AGPL-3.0-or-later",
  "author": "ccd2s",
  "contributors": [
    "ccd2s <tasaedem@outlook.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccd2s/yunhu-protobuf-typeproto"
  },
  "files": [
    "src",
    "lib",
    "README.md",
    "LICENSE"
  ],
